    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import time\n",
        "#python  list\n",
        "size = 1_000_000\n",
        "\n",
        "list1 = list(range(size))\n",
        "list2 = list(range(size))\n",
        "\n",
        "start = time.time()\n",
        "add = [x + y for x ,y in zip(list1,list2)]\n",
        "end = time.time()\n",
        "print(\"python list time: \",(end-start))\n"
      ],
